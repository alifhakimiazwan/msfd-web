# PostgreSQL connection string (Supabase or any Postgres provider)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Direct connection URL (used by Drizzle migrations, bypasses pooler)
DIRECT_URL=postgresql://user:password@host:5432/dbname

# Secret header value to protect the sync endpoint
# Authorization: Bearer <SYNC_SECRET>
SYNC_SECRET=change-me-to-a-long-random-string

# Data source: "local" reads ./data/grants.xlsx | "sharepoint" reads via Microsoft Graph
GRANTS_SOURCE=local

# SharePoint / Microsoft Graph (only needed when GRANTS_SOURCE=sharepoint)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_FILE_PATH=
